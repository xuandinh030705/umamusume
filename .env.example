# Database (Supabase PostgreSQL - Free Tier)
# Get your connection string from: https://supabase.com/dashboard → Settings → Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
# Generate a secret at: https://generate-secret.vercel.app/32
NEXTAUTH_URL="https://umawall.vercel.app"
NEXTAUTH_SECRET="your-production-secret-here"

# OAuth (Google)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary (for file uploads)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# App
NEXT_PUBLIC_SITE_URL="https://umawall.vercel.app"
NEXT_PUBLIC_SITE_NAME="UmaWall"
